# 4ztexDock — user config file
# Location: ~/.config/4ztexDock/config.ini
#
# Every key is optional. This file is a reference template — uncomment what
# you want to change and delete the rest. After editing, restart the dock:
#   pkill -x 4ztexDock; /usr/bin/4ztexDock &; disown

[Display]
# Which screen the dock should open on. Empty = auto (KDE primary → Qt primary).
# Accepts the connector name (DP-1, HDMI-A-1, eDP-1) or
# manufacturer/model/serial. `4ztexDock --help` shows the available screens
# at startup.
#screen=DP-3

[Appearance]
# Accent color — slider sub-page, focused border, active row highlight.
# Format: R,G,B (each 0-255).
# Default: 167,139,250 (violet-400 — Tailwind palette)
# Other suggestions:
#   59,130,246    blue-500
#   34,197,94     green-500
#   239,68,68     red-500
#   249,115,22    orange-500
#accent=167,139,250

[Launcher]
# How many apps to show in the Frequent grid (1-16).
# Default: 8 (4×2 grid). Larger values make the launcher menu taller.
#frequentLimit=8
